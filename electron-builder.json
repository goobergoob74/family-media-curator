{
  "name": "family-media-curator",
  "productName": "Family Media Curator",
  "version": "0.0.1",
  "description": "Organize, rename, deduplicate, and enrich your family photo/video archive",
  "main": "dist/main/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build"
  },
  "build": {
    "appId": "com.zoo.family-media-curator",
    "productName": "Family Media Curator",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.photography",
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
